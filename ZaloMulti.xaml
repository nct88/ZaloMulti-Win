<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý ZalỏMulti" Height="700" Width="1000"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="__FONT_PATH__">
    <Window.Resources>
        <!-- Hệ thống màu sắc (Mặc định Tối) -->
        <SolidColorBrush x:Key="BgDark" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="BgSidebar" Color="#18191A"/>
        <SolidColorBrush x:Key="BgCard" Color="#242526"/>
        <SolidColorBrush x:Key="BgToggle" Color="#3A3B3C"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3E4042"/>
        <SolidColorBrush x:Key="TextMain" Color="#E4E6EB"/>
        <SolidColorBrush x:Key="TextSec" Color="#B0B3B8"/>
        
        <SolidColorBrush x:Key="AccentBlue" Color="#007AFF"/>
        <SolidColorBrush x:Key="AccentGradBrush" Color="#007AFF"/>
        <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF"/>
 
        <!-- Sửa lỗi Font toàn cục -->
        <Style TargetType="Control">
            <Setter Property="FontFamily" Value="__FONT_PATH__"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="__FONT_PATH__"/>
        </Style>

        <!-- Định nghĩa kiểu dáng Button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SocialBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="17" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <ContentPresenter Margin="8"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentGradBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorCircle" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="{DynamicResource BgDark}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Thanh bên -->
            <Border Grid.Column="0" Background="{DynamicResource BgSidebar}" CornerRadius="10,0,0,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="25">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,35">
                            <Image Name="ImgLogo" Width="40" Height="40" Stretch="Uniform"/>
                            <StackPanel Margin="15,0,0,0">
                                <TextBlock Text="ZalỏMulti" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                                <TextBlock Name="TxtVersion" Text="Đang tải..." FontSize="12" Foreground="{DynamicResource TextSec}" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>


                        
                        <Button Name="BtnAdd" Content="Thêm tài khoản" Style="{StaticResource AccentBtn}" FontSize="16" Margin="0,0,0,15"/>
                        
                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Name="BtnExport" Content="📦 Sao lưu" Style="{StaticResource RoundBtn}" Grid.Column="0" Margin="0,0,5,0" FontSize="13"/>
                            <Button Name="BtnImport" Content="📥 Khôi phục" Style="{StaticResource RoundBtn}" Grid.Column="1" Margin="5,0,0,0" FontSize="13"/>
                        </Grid>
                        
                        <TextBlock Text="Đổi chủ đề Sáng/Tối" Foreground="{DynamicResource TextSec}" FontSize="14" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        <Border Background="{DynamicResource BgToggle}" CornerRadius="10" Padding="4" HorizontalAlignment="Center">
                            <Grid Width="80" Height="32">
                                <!-- Thanh trượt highlight -->
                                <Border Name="ThemeIndicator" Background="{DynamicResource AccentBlue}" Width="40" Height="32" CornerRadius="8" HorizontalAlignment="Left">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0" />
                                    </Border.RenderTransform>
                                </Border>
                                
                                <StackPanel Orientation="Horizontal">
                                    <Button Name="BtnLight" Content="☀️" Width="40" Height="32" Style="{StaticResource ActionBtn}" Background="Transparent"/>
                                    <Button Name="BtnDark" Content="🌙" Width="40" Height="32" Style="{StaticResource ActionBtn}" Background="Transparent"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Button Name="BtnFB" Style="{StaticResource SocialBtn}">
                                <Image Name="ImgFB" Stretch="Uniform"/>
                            </Button>
                            <Button Name="BtnTG" Style="{StaticResource SocialBtn}">
                                <Image Name="ImgTG" Stretch="Uniform"/>
                            </Button>
                            <Button Name="BtnGH" Style="{StaticResource SocialBtn}">
                                <Image Name="ImgGH" Stretch="Uniform"/>
                            </Button>
                            <Button Name="BtnWS" Style="{StaticResource SocialBtn}">
                                <Image Name="ImgWS" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                        <Button Name="BtnKillAll" Content="Đóng tất cả các Zalo" Style="{StaticResource ActionBtn}" Foreground="#FF5555" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Nội dung chính -->
            <Grid Grid.Column="1" Margin="35">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Tài khoản đang hoạt động" FontSize="30" FontWeight="Black" Foreground="{DynamicResource TextMain}"/>
                        <TextBlock Text="Quản lý các tài khoản Zalo của bạn một cách dễ dàng." FontSize="14" Foreground="{DynamicResource TextSec}" Margin="0,5,0,0"/>
                    </StackPanel>
                    
                    <Button Name="BtnClose" Content="Đóng ứng dụng" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Style="{StaticResource ActionBtn}" Background="Transparent" Foreground="{DynamicResource TextSec}" 
                            FontSize="14" Margin="0,-20,-10,0"/>
                </Grid>

                <Grid Grid.Row="1">
                    <ScrollViewer Name="MainScroll" VerticalScrollBarVisibility="Hidden">
                        <WrapPanel Name="InstanceGrid" ItemWidth="330">
                            <!-- Nội dung động sẽ xuất hiện ở đây -->
                        </WrapPanel>
                    </ScrollViewer>
                    
                    <Button Name="BtnToTop" Content="↑" Style="{StaticResource ActionBtn}" 
                            Background="{DynamicResource BgToggle}" Width="40" Height="40" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                            Margin="0,0,20,20" Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
<!-- Bản quyền thuộc về truong.it - Tác giả: truong.it -->
